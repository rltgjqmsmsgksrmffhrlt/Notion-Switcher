{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "3.2.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Notion Switcher (Alt+N)"
  },
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "windows": "Alt+N",
        "mac": "Alt+N",
        "linux": "Alt+N"
      },
      "description": "__MSG_commandPopup__"
    },
    "open-dashboard": {
      "suggested_key": {
        "windows": "Alt+Shift+N",
        "mac": "Alt+Shift+N",
        "linux": "Alt+Shift+N"
      },
      "description": "__MSG_commandDashboard__"
    }
  }
}
